// =============================================================  Provider  =============================================================


/* 
  in Flutter, a provider is a way to manage state and share data across the widget tree. 
  it is a package that allows us to create a central place to store our data and then access that data from any widget in the widget tree 
  without having to pass it down through the widget tree manually.



  problem:
      like if we have to send a data from let say one widget to another we have pass it like child to child to child.
      page1  ->  page2  ->  page3  ->  page4  ->  page5
        so we need a way to pass a data from page1 to page5 without having to pass it through all the intermediate pages.



  solution: we use provider so that we store just in one place but can access from another palces



  there are some type of provider that we can use in our app like 
    1. ChangeNotifierProvider
    2. FutureProvider
    3. StreamProvider
    4. provider (this is the basic provider that we can use to create our own provider)

*/


// changeNotifierProvider example
class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return ChangeNotifierProvider(
      create: (_) => ActivityManagementProvider(),  

      //  here ActivityManagementProvider is a extended of a changeNotifier class that we have created to manage our state and data. 
      //  this is the provider that we will use to manage our state and data.

      child: MaterialApp(
        debugShowCheckedModeBanner: false,
        home: const MainPage(),
      ),
    );
  }
}

class ActivityManagementProvider extends ChangeNotifier {
  // this is the provider class that we will use to manage our state and data. 

  //  we can create any variable or function here that we want to use in anyware of our app and then we can access it from any widget in the widget tree 
  //   Provider.of<ActivityManagementProvider>(context) or context.watch<ActivityManagementProvider>() or 
  //  context.read<ActivityManagementProvider>().

  int _counter = 0;

  int get counter => _counter;

  void incrementCounter() {
    _counter++;
    notifyListeners(); // this is used to notify the listeners that there is a change in the state so that they can rebuild the widget tree with the new data.
  }
}


final provider = context.read<ActivityManagementProvider>(); 
/*  
  this is how we can access the provider from any widget in the widget tree. 
  we can use this to call any function or access any variable that we have in the provider class.

    read() is used because:
    we just want to call a function that is defined inside of the ActivityManagementProvider class
    no need to rebuild here 
*/

final provider =context.watch<ActivityManagementProvider>();       // here both line are same 
final provider = Provider.of<ActivityManagementProvider>(context);

/*  
   provider is listenig or we can say just waiting for any change in the data that is defined in the ActivityManagementProvider class 
    and when there is a change it will rebuild the widget tree with the new data.
    if we call the function incrementCounter() that is defined in the provider class 
    then it will change the value of counter and then it will call notifyListeners() which will notify the listeners that there is a change in the state 
    so that they can rebuild the widget tree with the new data.
  


    Gets provider
    Listens to changes
    Rebuilds UI when data changes
*/


final provider = Provider.of<ActivityManagementProvider>(context, listen: false);  // this both line are same
final provider = context.read<ActivityManagementProvider>(); 